# ── Shared ───────────────────────────────────────────────────────────────────
# A long random string that the bot sends as a header so only it can call /set-status
STAFF_SECRET=replace-with-a-long-random-string

# ── Backend ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017

# ── Discord Bot ───────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token-here
API_BASE=http://localhost:8000

# The numeric ID of your "Staff" role in Discord
# Right-click the role → Copy ID (enable Developer Mode in Discord settings first)
STAFF_ROLE_ID=123456789012345678
